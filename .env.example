# -------------------------------------------------------
# GigaChat (Sber) — PRIMARY for Sber demo
# Get credentials from: https://developers.sber.ru/gigachat
# -------------------------------------------------------
GIGACHAT_AUTH_KEY=        # Base64 Authorization key from Sber cabinet
GIGACHAT_SCOPE=GIGACHAT_API_PERS   # or GIGACHAT_API_CORP for corporate

# -------------------------------------------------------
# Anthropic Claude — FALLBACK (used when GigaChat not set)
# -------------------------------------------------------
ANTHROPIC_API_KEY=

# -------------------------------------------------------
# LOCAL DEV NOTE: if GigaChat token endpoint returns SSL errors
# (port 9443 uses self-signed cert), add this to .env.local only:
# NODE_TLS_REJECT_UNAUTHORIZED=0
# NEVER set this in production.
# -------------------------------------------------------
